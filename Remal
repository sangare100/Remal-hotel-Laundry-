        function performSearch() {
            const t = translations[currentLang] || translations['en'];
            const searchVal = document.getElementById('search-room').value.toLowerCase().trim();
            const searchDt = document.getElementById('search-date').value;
            const searchType = document.getElementById('search-type').value;
            
            if (searchDt) { btnPrintPdf.classList.remove('hidden'); btnPrintPdf.classList.add('flex'); } 
            else { btnPrintPdf.classList.add('hidden'); btnPrintPdf.classList.remove('flex'); }

            if(!searchVal && !searchDt && searchType === "all") { searchResultsContainer.innerHTML = ''; searchResultsContainer.classList.add('hidden'); return; }
            searchResultsContainer.innerHTML = ''; searchResultsContainer.classList.remove('hidden');

            let allHistory = [...entries, ...spaEntries, ...pastArchives];
            const filtered = allHistory.filter(h => {
                const matchDt = searchDt ? h.dateYMD == searchDt : true;
                let matchType = true;
                if(searchType === "rooms") matchType = h.room !== undefined;
                if(searchType === "spa") matchType = h.isSpa === true;
                
                let matchVal = true;
                if(searchVal) {
                    if(h.isSpa) matchVal = h.collectedBy.toLowerCase().includes(searchVal) || h.deliveredBy.toLowerCase().includes(searchVal) || (h.serial && h.serial.toLowerCase().includes(searchVal));
                    else matchVal = h.room && h.room.toString().includes(searchVal);
                }
                return matchDt && matchType && matchVal;
            });

            if(filtered.length === 0) { searchResultsContainer.innerHTML = `<div class="text-[11px] text-slate-400 italic py-1">${t.searchNoResult}</div>`; return; }

            filtered.reverse().forEach(h => {
                const div = document.createElement('div');
