                } else {
                    div.className = "text-[11px] bg-slate-800 p-2 rounded-lg border border-slate-700 text-slate-300 flex justify-between items-center";
                    let detail = h.status !== "No Laundry" ? ` (${t.labelHanger.charAt(0)}:${h.hanger} | ${t.labelFolding.charAt(0)}:${h.folding})` : '';
                    let extraTag = h.surplus > 0 ? ` <span class="text-red-400 font-bold">[+${h.surplus}]</span>` : '';
                    div.innerHTML = `<div>📅 <b>${h.dateReadable}</b> - ${h.time} ➔ <b>Rm ${h.room}</b>${extraTag}</div><div class="text-right"><span class="px-1.5 py-0.5 rounded text-[9px] font-bold bg-slate-700 text-[#e3b28d]">${h.status}${detail}</span></div>`;
                }
                searchResultsContainer.appendChild(div);
            });
        }

        window.generateA4Report = function() {
            const searchDt = document.getElementById('search-date').value;
            if(!searchDt) return;

            const allHistory = [...entries, ...spaEntries, ...pastArchives];
            const targetDayData = allHistory.filter(h => h.dateYMD === searchDt);

            document.getElementById('pdf-report-date').innerText = new Date(searchDt).toLocaleDateString(currentLang, { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });
            
            const roomsTbody = document.getElementById('pdf-rooms-tbody');
            const spaTbody = document.getElementById('pdf-spa-tbody');
            roomsTbody.innerHTML = ''; spaTbody.innerHTML = '';

            const roomRecords = targetDayData.filter(h => h.room !== undefined);
            const spaRecords = targetDayData.filter(h => h.isSpa === true);

            if(roomRecords.length === 0) {
                roomsTbody.innerHTML = `<tr><td colspan="5" class="py-4 text-center text-slate-400 italic">No room laundry data recorded for this date.</td></tr>`;
            } else {
                roomRecords.forEach(r => {
                    roomsTbody.innerHTML += `<tr class="border-b border-slate-100"><td class="py-2 font-bold">Room ${r.room}</td><td class="py-2">${r.status} <span class="text-[10px] text-slate-400">(${r.time})</span></td><td class="py-2">${r.hanger}</td><td class="py-2">${r.folding}</td><td class="py-2 text-right font-bold text-red-600">${r.surplus > 0 ? '+' + r.surplus : '-'}</td></tr>`;
                });
            }

            if(spaRecords.length === 0) {
                spaTbody.innerHTML = `<tr><td colspan="9" class="py-4 text-center text-slate-400 italic">No spa laundry data recorded for this date.</td></tr>`;
            } else {
                spaRecords.forEach(s => {
                    spaTbody.innerHTML += `<tr class="border-b border-slate-100"><td class="py-2 font-bold text-teal-800">${s.serial || '-'}</td><td class="py-2">${s.time}</td><td class="py-2">${s.sheets}</td><td class="py-2">${s.towels}</td><td class="py-2">${s.handTowels}</td><td class="py-2">${s.bathrobes}</td><td class="py-2">${s.pillows}</td><td class="py-2 text-slate-600 text-[9px]">C:${s.collectedBy}<br>D:${s.deliveredBy}</td><td class="py-2 text-right font-bold text-emerald-700">${s.totalPrice} AED</td></tr>`;
                });
            }

            const appContainer = document.getElementById('app-container');
            const printArea = document.getElementById('a4-printable-area');

            appContainer.classList.add('hidden');
            printArea.classList.remove('hidden');

            window.print();

            setTimeout(() => {
                printArea.classList.add('hidden');
                appContainer.classList.remove('hidden');
            }, 500);
        };

        document.getElementById('search-room').addEventListener('input', performSearch);
        document.getElementById('search-date').addEventListener('change', performSearch);
        document.getElementById('search-type').addEventListener('change', performSearch);

        document.getElementById('laundry-form').addEventListener('submit', (e) => {
            e.preventDefault();
            const room = roomInput.value.trim(); const status = document.querySelector('input[name="status-type"]:checked').value;
            if(!checkRoomValidity(room)) { validationMsg.classList.remove('hidden'); return; }
            validationMsg.classList.add('hidden');
            const surplusAmount = checkSurplus(); const now = new Date();
            entries.push({ room, status, time: now.toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'}), dateYMD: now.toISOString().split('T')[0], dateReadable: now.toLocaleDateString(currentLang, { day: 'numeric', month: 'short' }), hanger: hangerCount, folding: foldingCount, surplus: surplusAmount });
            roomInput.value = ''; resetCounters(); broadcastData();
        });

        document.getElementById('spa-form').addEventListener('submit', (e) => {
            e.preventDefault();
            const serial = document.getElementById('spa-serial').value.trim();
            if(spaSheets === 0 && spaTowels === 0 && spaHandTowels === 0 && spaBathrobes === 0 && spaPillows === 0) { alert("Please count at least 1 item for Spa!"); return; }
            const collectedBy = document.getElementById('spa-collected-by').value.trim(); const deliveredBy = document.getElementById('spa-delivered-by').value.trim();
            const totalPrice = updateSpaLivePrices();
            const now = new Date();
            
            spaEntries.push({ isSpa: true, serial, sheets: spaSheets, towels: spaTowels, handTowels: spaHandTowels, bathrobes: spaBathrobes, pillows: spaPillows, collectedBy, deliveredBy, totalPrice, time: now.toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'}), dateYMD: now.toISOString().split('T')[0], dateReadable: now.toLocaleDateString(currentLang, { day: 'numeric', month: 'short' }) });
            resetSpaCounters(); broadcastData();
        });

        document.getElementById('store-form').addEventListener('submit', (e) => {
            e.preventDefault(); const t = translations[currentLang] || translations['en'];
            const room = document.getElementById('store-room').value.trim(); const checkoutDate = document.getElementById('store-date').value; const details = document.getElementById('store-details').value.trim();
            if(!checkRoomValidity(room)) { alert(t.alertInvalid); return; }
            storeEntries.push({ room, checkoutDate, details });
            document.getElementById('store-room').value = ''; document.getElementById('store-details').value = ''; broadcastData();
        });

        document.getElementById('clear-all').addEventListener('click', () => { 
            const t = translations[currentLang] || translations['en'];
            if(confirm(t.confirmArchive)) { pastArchives = [...pastArchives, ...entries, ...spaEntries]; entries = []; spaEntries = []; broadcastData(); } 
        });

        function buildReportText() {
            let textReport = `📋 *REMAL HOTEL & VILLAS - DAILY LAUNDRY REPORT*\n\n`;
            textReport += `✨ *ROOMS COLLECTION*:\n`;
            entries.forEach(e => {
                textReport += `- Room ${e.room} ➔ *${e.status}*`;
                if (e.status !== "No Laundry") {
                    textReport += ` (Hanger: ${e.hanger} | Folding: ${e.folding})`;
                    if (e.surplus > 0) textReport += ` ⚠️ *[+${e.surplus} CHARGEABLE]*`;
                }
                textReport += ` [${e.time}]\n`;
            });
            if(spaEntries.length > 0) {
                textReport += `\n🧖‍♂️ *SPA LAUNDRY COLLECTION*:\n`;
                spaEntries.forEach(s => {
                    textReport += `- S/N: ${s.serial} ➔ *Total: ${s.totalPrice} AED* (Sheets:${s.sheets} | Towels:${s.towels} | Hand:${s.handTowels} | Robes:${s.bathrobes} | Pillows:${s.pillows}) [C:${s.collectedBy} / D:${s.deliveredBy}] (${s.time})\n`;
                });
            }
            return textReport;
        }

        document.getElementById('whatsapp-btn').addEventListener('click', () => { if (entries.length === 0 && spaEntries.length === 0) return; window.open(`https://api.whatsapp.com/send?text=${encodeURIComponent(buildReportText())}`, '_blank'); });
        langSelect.addEventListener('change', (e) => changeLanguage(e.target.value));
        
        changeLanguage(currentLang); pullCloudData();
    </script>
</body>
</html>
